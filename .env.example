# Florida County RAG - Environment Configuration
# Copy to .env and fill in credentials (do not commit .env)

# Embeddings API (required for indexing + retrieval)
EMBEDDINGS_API_KEY=
EMBEDDINGS_BASE_URL=https://api.ai.it.ufl.edu/v1
EMBEDDINGS_MODEL=nomic-embed-text-v1.5

# LLM API (RAG answers + classifiers; defaults to embeddings key/base if unset)
LLM_API_KEY=
LLM_BASE_URL=https://api.ai.it.ufl.edu/v1
# Default in src/config.py if unset: llama-3.1-8b-instruct (confirm your gateway allows this model)
LLM_MODEL=llama-3.1-8b-instruct
